rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role in ['admin', 'school_admin'];
    }

    function isTeacher(schoolId) {
      return isSignedIn() &&
        getUserData().role in ['teacher', 'admin', 'school_admin'] &&
        getUserData().schoolId == schoolId;
    }

    // ── /users 컬렉션 ───────────────────────────────────────────
    match /users/{uid} {
      // 본인 문서 읽기 (role 확인용)
      allow read: if isSignedIn() && request.auth.uid == uid;
      // 첫 로그인 시 문서 생성: 교사는 pending, 학생은 student
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.role in ['pending', 'student'];
      // 본인 정보 갱신 허용 (이름·familyName 등, role·schoolId는 변경 불가), 관리자는 모든 변경 가능
      allow update: if isAdmin() ||
                    (isSignedIn() && request.auth.uid == uid &&
                     request.resource.data.role == resource.data.role &&
                     request.resource.data.schoolId == resource.data.schoolId);
      // 관리자 전체 목록 + 교사는 학생 계정만 조회 가능
      allow list: if isAdmin() || isSignedIn();
    }

    // ── /schools 컬렉션 ────────────────────────────────────────
    match /schools/{schoolId} {
      allow read: if isTeacher(schoolId);
      allow write: if false;

      match /teachers/{teacherId} {
        allow read, write: if isTeacher(schoolId);
      }

      match /students/{studentId} {
        allow read: if isTeacher(schoolId) || isSignedIn();
        allow write: if isTeacher(schoolId);
      }

      match /studentGroups/{groupId} {
        // 학교 교사(schoolId 일치): 전체 접근
        // 본인이 생성한 그룹: schoolId 불일치여도 본인은 항상 접근 가능
        allow read: if isTeacher(schoolId) ||
          (isSignedIn() && resource.data.createdBy == request.auth.uid);
        allow write: if isTeacher(schoolId) ||
          (isSignedIn() && (resource.data.createdBy == request.auth.uid ||
                            request.resource.data.createdBy == request.auth.uid));
      }

      match /courses/{courseId} {
        allow read: if isTeacher(schoolId);
        allow write: if isTeacher(schoolId);
      }

      match /events/{eventId} {
        allow read: if isTeacher(schoolId) || isSignedIn();
        allow write: if isTeacher(schoolId);

        match /attendanceLogs/{logId} {
          allow read: if isTeacher(schoolId) || isSignedIn();
          // 교사 수정 또는 qrToken/liveToken 일치 시 학생 write 허용
          allow write: if isTeacher(schoolId) ||
            get(/databases/$(database)/documents/schools/$(schoolId)/events/$(eventId)).data.qrToken
              == request.resource.data.qrToken ||
            get(/databases/$(database)/documents/schools/$(schoolId)/events/$(eventId)).data.liveToken
              == request.resource.data.qrToken;
        }
      }

      match /trainings/{trainingId} {
        allow read: if isTeacher(schoolId);
        allow create: if isTeacher(schoolId);
        allow update: if isTeacher(schoolId);
        allow delete: if isAdmin() || (isTeacher(schoolId) && resource.data.createdBy == request.auth.uid);

        match /signatures/{signatureId} {
          allow read: if isTeacher(schoolId);
          allow write: if isTeacher(schoolId) && request.auth.uid == signatureId;
        }
      }

      match /trainingPresets/{presetId} {
        allow read: if isTeacher(schoolId);
        allow write: if isAdmin();
      }
    }
  }
}
