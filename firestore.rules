rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // [C-1] Custom Claims 방식 — 이메일 하드코딩 제거
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.superAdmin == true;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role in ['admin', 'school_admin'];
    }

    function isSchoolAdmin(schoolId) {
      return isSignedIn() &&
        getUserData().role in ['admin', 'school_admin'] &&
        getUserData().schoolId == schoolId;
    }

    function isTeacher(schoolId) {
      return isSignedIn() &&
        getUserData().role in ['teacher', 'admin', 'school_admin', 'principal'] &&
        getUserData().schoolId == schoolId;
    }

    function isPrincipal(schoolId) {
      return isSignedIn() &&
        getUserData().role == 'principal' &&
        getUserData().schoolId == schoolId;
    }

    function isStudent(schoolId) {
      return isSignedIn() &&
        getUserData().role == 'student' &&
        getUserData().schoolId == schoolId;
    }

    // asaSubmissions 문서 자체의 teacherEmails는 생성 시점 스냅샷이라, 나중에 asaSubjects에서
    // 교사가 추가/제거돼도 기존 submission 문서에는 반영되지 않아 배정 현황과 어긋날 수 있다.
    // 그래서 배정 여부는 항상 asaSubjects의 실시간 teacherEmails로 판단한다.
    function isAssignedToAsaSubject(schoolId, subjectId) {
      return request.auth.token.email in
        get(/databases/$(database)/documents/schools/$(schoolId)/asaSubjects/$(subjectId)).data.teacherEmails;
    }

    // ── /studentRegistrations — 학생 자동 등록용 이메일 색인 ───────
    match /studentRegistrations/{email} {
      allow get: if isSignedIn() && email == request.auth.token.email;
      allow list: if isSuperAdmin();
      allow create, update: if isSuperAdmin() || isTeacher(request.resource.data.schoolId);
      allow delete: if isSuperAdmin() || isTeacher(resource.data.schoolId);
    }

    // ── /schoolDomains — get만 허용 (auth 흐름 자기 도메인 조회) ──────
    match /schoolDomains/{domain} {
      allow get: if isSignedIn();
      allow list: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // ── /auditLogs ──────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isSignedIn();  // SchoolSetup·SuperAdmin 모두 기록
      allow update, delete: if isSuperAdmin();
    }

    // ── /users ──────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.role in ['pending', 'student', 'school_admin', 'teacher'];
      allow update: if isSuperAdmin() || isAdmin() ||
                    (isSignedIn() && request.auth.uid == uid &&
                     request.resource.data.role == resource.data.role &&
                     request.resource.data.schoolId == resource.data.schoolId) ||
                    // [M-2] 게스트 → 실제 학교 전환: role은 pending/teacher만 허용 (admin 제외)
                    (isSignedIn() && request.auth.uid == uid &&
                     resource.data.schoolId.matches('guest_.*') &&
                     request.resource.data.role in ['pending', 'teacher']) ||
                    // [M-4] 학생 이메일 패턴으로 본인 역할 복구 (rejected/pending → student)
                    (isSignedIn() && request.auth.uid == uid &&
                     resource.data.role in ['rejected', 'pending'] &&
                     request.resource.data.role == 'student' &&
                     request.auth.token.email.matches('[0-9]{9}@.*'));
      allow delete: if isSuperAdmin();
      allow list: if isSuperAdmin() || isAdmin();  // 전체 목록은 관리자만
    }

    // ── /schools ─────────────────────────────────────────────────
    match /schools/{schoolId} {
      // [H-1] get/list 분리 — list는 관리자만, 단건 get은 SchoolSetup 미가입자도 허용
      allow get: if isSuperAdmin() || isTeacher(schoolId) || isSignedIn();
      // [FIX] list는 원래 관리자/소속 교사만 허용하려 했으나, schoolId는 문서마다 달라지는
      // 와일드카드라 컬렉션 전체를 조회하는 list 쿼리에서는 isTeacher(schoolId)가 절대 참이 될 수
      // 없어 SchoolSetup의 학교 검색이 슈퍼 어드민 외 전원에게 permission-denied로 막혀 있었음.
      // users 문서가 아직 없는(온보딩 전) 계정과 rejected 계정은 학교 목록을 조회할 수 있어야
      // SchoolSetup에서 소속 학교를 찾아 가입 신청할 수 있다.
      allow list: if isSuperAdmin() || isTeacher(schoolId) ||
        (isSignedIn() &&
          (!exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
           getUserData().role == 'rejected'));
      // 일반 사용자: school- 접두사 학교만 생성 가능 (SchoolSetup 자동 생성)
      allow create: if isSuperAdmin() ||
        (isSignedIn() && schoolId.matches('school-.*') && request.resource.data.createdBy == request.auth.token.email) ||
        (isSignedIn() && schoolId.matches('guest_.*') && request.resource.data.ownerUid == request.auth.uid);
      allow update: if isSuperAdmin() || isSchoolAdmin(schoolId);
      allow delete: if isSuperAdmin();

      // 보강 신청 — 소속 학교 구성원만 ────────────────────────────
      match /coverRequests/{requestId} {
        allow read: if isSuperAdmin() || isTeacher(schoolId);
        allow create: if isSuperAdmin() || isSchoolAdmin(schoolId);
        allow update: if isSuperAdmin() || isTeacher(schoolId);
        allow delete: if isSuperAdmin() || isSchoolAdmin(schoolId);
      }

      match /teachers/{teacherId} {
        allow read, write: if isSuperAdmin() || isTeacher(schoolId);
      }

      // 학생 — 소속 학교 구성원만 ──────────────────────────────────
      match /students/{studentId} {
        // 학생 본인도 자신의 학생 정보를 읽을 수 있음 (QR 체크인용)
        allow read: if isSuperAdmin() || isTeacher(schoolId) ||
          (isStudent(schoolId) && getUserData().studentId == studentId);
        allow write: if isSuperAdmin() || isTeacher(schoolId);
      }

      match /studentGroups/{groupId} {
        allow read: if isSuperAdmin() || isTeacher(schoolId) ||
          (isSignedIn() && resource.data.createdBy == request.auth.uid) ||
          (isStudent(schoolId) && resource.data.studentIds.hasAny([getUserData().studentId]));
        allow write: if isSuperAdmin() || isTeacher(schoolId) ||
          (isSignedIn() && (resource.data.createdBy == request.auth.uid ||
                            request.resource.data.createdBy == request.auth.uid));
      }

      match /courses/{courseId} {
        allow read: if isSuperAdmin() || isTeacher(schoolId);
        allow write: if isSuperAdmin() || isTeacher(schoolId);
      }

      // 이벤트 — QR 체크인(공개 get) 허용 ─────────────────────────
      match /events/{eventId} {
        allow get: if true;  // QR 체크인: 미로그인 학생 접근
        allow list: if isSuperAdmin() || isTeacher(schoolId) || isStudent(schoolId);
        allow write: if isSuperAdmin() || isTeacher(schoolId);

        match /attendanceLogs/{logId} {
          allow read: if isSuperAdmin() || isTeacher(schoolId);
          // 학생 본인의 출결 로그 확인 (중복 체크인 방지용 get)
          allow get: if isStudent(schoolId) &&
            (resource == null || resource.data.studentId == getUserData().studentId);
          // 학생: 순위 계산용 list (같은 학교 학생끼리 출석 현황 확인)
          allow list: if isStudent(schoolId);
          // [H-2] isSignedIn() 추가 — QR 토큰만으로 비로그인 쓰기 불가
          allow write: if isSuperAdmin() || isTeacher(schoolId) ||
            (isSignedIn() && (
              get(/databases/$(database)/documents/schools/$(schoolId)/events/$(eventId)).data.qrToken
                == request.resource.data.qrToken ||
              get(/databases/$(database)/documents/schools/$(schoolId)/events/$(eventId)).data.liveToken
                == request.resource.data.qrToken
            ));
        }

      }

      match /trainings/{trainingId} {
        allow read: if isSuperAdmin() || isTeacher(schoolId);
        allow create: if isSuperAdmin() || isTeacher(schoolId);
        allow update: if isSuperAdmin() || isTeacher(schoolId);
        allow delete: if isSuperAdmin() || isAdmin() ||
          (isTeacher(schoolId) && resource.data.createdBy == request.auth.uid);

        match /signatures/{signatureId} {
          allow read: if isSuperAdmin() || isTeacher(schoolId);
          allow write: if isSuperAdmin() ||
            (isTeacher(schoolId) && request.auth.uid == signatureId);
        }
      }

      match /trainingPresets/{presetId} {
        allow read: if isSuperAdmin() || isTeacher(schoolId);
        allow write: if isSuperAdmin() || isAdmin();
      }

      // 스마트 공지 — 본인 공지 쓰기, 소속 학교 구성원 읽기
      match /notices/{noticeId} {
        allow read: if isSuperAdmin() || isTeacher(schoolId) || isStudent(schoolId);
        allow write: if isSuperAdmin() ||
          (isTeacher(schoolId) && (
            resource == null || resource.data.teacherId == request.auth.uid
          ));

        // 공지 확인 기록 — 학생 본인만 쓰기, 교사는 읽기 가능
        match /confirmations/{confirmedStudentId} {
          allow read: if isSuperAdmin() || isTeacher(schoolId) ||
            (isStudent(schoolId) && getUserData().studentId == confirmedStudentId);
          allow create, update: if isSuperAdmin() ||
            (isStudent(schoolId) && getUserData().studentId == confirmedStudentId);
          allow delete: if isSuperAdmin() || isTeacher(schoolId);
        }
      }

      // [M-3] preApproved — 본인 이메일 문서만 get 허용, 목록은 해당 학교 관리자 이상
      match /preApproved/{emailId} {
        allow get: if isSignedIn() && emailId == request.auth.token.email;
        allow list: if isSuperAdmin() || isSchoolAdmin(schoolId);
        allow write: if isSuperAdmin() || isSchoolAdmin(schoolId);
      }

      // ── 성취평가제 운영 체크리스트 (ASA-checklist) ──────────────
      // 과목 — 관리자만 생성/수정, 교사·교감은 조회
      match /asaSubjects/{subjectId} {
        allow read: if isSuperAdmin() || isTeacher(schoolId);
        allow write: if isSuperAdmin() || isSchoolAdmin(schoolId);
      }

      // 나이스 담당과목 업로드 이력 — 관리자만 (교사 로스터 데이터, 관리 목적 전용)
      match /asaNeisImports/{importId} {
        allow read: if isSuperAdmin() || isSchoolAdmin(schoolId);
        allow write: if isSuperAdmin() || isSchoolAdmin(schoolId);
      }

      // 제출물 — 배정된 교사·교감은 읽기/수정, 관리자는 전체, 잠금(locked) 후 수정 불가
      // 배정 여부는 문서 자체의 teacherEmails(스냅샷)가 아니라 asaSubjects의 실시간 값으로 판단
      match /asaSubmissions/{submissionId} {
        allow read: if isSuperAdmin() || isSchoolAdmin(schoolId) || isPrincipal(schoolId) ||
          (isTeacher(schoolId) && isAssignedToAsaSubject(schoolId, resource.data.subjectId));
        allow create: if isSuperAdmin() || isSchoolAdmin(schoolId) ||
          (isTeacher(schoolId) && isAssignedToAsaSubject(schoolId, request.resource.data.subjectId));
        allow update: if isSuperAdmin() || isSchoolAdmin(schoolId) || isPrincipal(schoolId) ||
          (isTeacher(schoolId) &&
           isAssignedToAsaSubject(schoolId, resource.data.subjectId) &&
           resource.data.status != 'locked');
        allow delete: if isSuperAdmin() || isSchoolAdmin(schoolId);
      }

      // 교감 서명 재사용 저장소 — 본인만 읽기/쓰기, 관리자는 읽기
      match /asaPrincipalSignature/{uid} {
        allow read: if isSuperAdmin() || isSchoolAdmin(schoolId) ||
          (isSignedIn() && request.auth.uid == uid);
        allow write: if isSuperAdmin() ||
          (isPrincipal(schoolId) && request.auth.uid == uid);
      }

      // 성취평가제 체크리스트 지원 도구 (ASA-support)
      // 분할점수 기준 — 조회는 소속 교사 전체, 등록/수정/삭제는 관리자만
      match /asaCutoffs/{cutoffId} {
        allow read: if isSuperAdmin() || isTeacher(schoolId);
        allow write: if isSuperAdmin() || isSchoolAdmin(schoolId);
      }

      // 분석 결과 — 업로드한 본인 교사만 조회/수정/삭제 (관리자는 전체 열람 가능)
      match /asaResults/{resultId} {
        allow read: if isSuperAdmin() || isSchoolAdmin(schoolId) ||
          (isTeacher(schoolId) && resource.data.createdBy == request.auth.uid);
        allow create: if isSuperAdmin() ||
          (isTeacher(schoolId) && request.resource.data.createdBy == request.auth.uid);
        allow update, delete: if isSuperAdmin() || isSchoolAdmin(schoolId) ||
          (isTeacher(schoolId) && resource.data.createdBy == request.auth.uid);
      }
    }
  }
}
